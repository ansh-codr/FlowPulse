rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profile ─────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // ── Settings ──────────────────────────────────────────
      match /settings/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Lightweight daily realtime summary ────────────────
      match /dailyRealtime/{dateId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.userId == userId
          && request.resource.data.date == dateId
          && request.resource.data.steps is int
          && request.resource.data.steps >= 0
          && request.resource.data.activitySummary.focusScore is int
          && request.resource.data.activitySummary.focusScore >= 0
          && request.resource.data.activitySummary.focusScore <= 100
          && request.resource.data.activitySummary.activeMinutes is int
          && request.resource.data.activitySummary.activeMinutes >= 0
          && request.resource.data.activitySummary.productiveMinutes is int
          && request.resource.data.activitySummary.productiveMinutes >= 0
          && request.resource.data.activitySummary.distractionCount is int
          && request.resource.data.activitySummary.distractionCount >= 0
          && request.resource.data.activitySummary.sessionCount is int
          && request.resource.data.activitySummary.sessionCount >= 0
          && request.resource.data.activitySummary.topDomain is string
          && request.resource.data.lastUpdated is timestamp;
        allow delete: if false;
      }

      // ── Legacy heavy activity logs (disabled for client writes) ─
      match /activityLogs/{logId} {
        allow read, write: if false;
      }

      // ── Daily stats (client + Cloud Functions can write for MVP) ─
      match /dailyStats/{dateId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Nudges (client + Cloud Functions can write for MVP) ────
      match /nudges/{nudgeId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dismissed']);
        allow create: if request.auth != null && request.auth.uid == userId;
        allow delete: if false;
      }

      // ── Mobile activity summaries (read-only for users; writes via Admin SDK) ────
      match /mobile_activity_summary/{dateId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // ── Integration tokens (never client-accessible; managed by Cloud Functions) ────
      match /integrations/{integrationId} {
        allow read, write: if false;
      }

      // ── Combined cross-device analytics (read-only for dashboard; writes via Admin SDK) ────
      match /combined_analytics/{dateId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // ── Health awareness alerts (generated server-side, dismissible in dashboard) ────
      match /health_alerts/{alertId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dismissed', 'updatedAt']);
        allow create, delete: if false;
      }
    }

    // ── Leaderboard (public read, admin write) ──────────────
    match /leaderboard/{weekId} {
      allow read: if request.auth != null;
      allow write: if false; // Only Cloud Functions (admin SDK)

      match /entries/{entryId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }
  }
}
